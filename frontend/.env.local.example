# =============================================================================
# frontend/.env.local.example  —  LOCAL DEVELOPMENT environment
# Copy to:  frontend/.env     (cp .env.local.example .env)
# Source of truth: frontend/vite.config.ts (dev server :8004, proxy -> :8005),
#                  src/lib/api.ts, src/lib/utils.ts, src/pages/.../DirectCustomerPayment.tsx
# =============================================================================
#
# RECOMMENDED LOCAL MODE = "Vite proxy" (matches vite.config.ts):
#   - Vite dev server runs on http://localhost:8004
#   - It proxies  /api  -> http://localhost:8005  and  /ws -> ws://localhost:8005
#   - So run the Django backend on PORT 8005.
#   - Leave the URL vars BELOW EMPTY: the app then uses same-origin (:8004) requests
#     which Vite forwards to :8005. This AVOIDS CORS entirely (see LOCAL_ENV_SETUP.md).
#
# Do NOT point these at http://localhost:8005 directly: a cross-origin call from
# :8004 would be blocked, because in DEBUG the backend CORS allowlist is hard-coded
# to ports 3000/3001/3002 only and ignores env. The proxy is the clean path.
# -----------------------------------------------------------------------------

# VITE_API_URL — REST base URL (src/lib/api.ts).
# Empty -> axios baseURL '' -> relative '/api/...' -> Vite proxy -> backend :8005.
# Purpose: backend REST base.  Recommended local value: EMPTY.
VITE_API_URL=

# VITE_WS_URL — WebSocket base URL (src/lib/api.ts).
# Empty -> resolves to ws://<window.host> = ws://localhost:8004 -> Vite /ws proxy -> :8005.
# Purpose: Django Channels WebSocket base.  Recommended local value: EMPTY.
VITE_WS_URL=

# VITE_API_BASE_URL — used ONLY by DirectCustomerPayment.tsx.
# Code default if unset/empty: 'http://localhost:8004' (which the Vite proxy forwards).
# Purpose: alt REST base for the direct-payment screen.  Recommended local value: EMPTY.
VITE_API_BASE_URL=

# VITE_BASE_PATH — app base path (vite.config.ts base + router).
# Default in code: '/'.  Production serves under '/dashboard/'.
# Purpose: SPA mount path.  Recommended local value: /
VITE_BASE_PATH=/

# VITE_SPECIAL_CHARS — allowed special chars for the password generator (src/lib/utils.ts).
# Code default if unset: '@$!%*?&' (must match backend password policy).
# Purpose: keep client password gen aligned with backend validation.
# Recommended local value: @$!%*?&
VITE_SPECIAL_CHARS=@$!%*?&

# =============================================================================
# ALTERNATIVE "direct" mode (NOT recommended; needs a backend CORS change):
#   VITE_API_URL=http://localhost:8005
#   VITE_WS_URL=ws://localhost:8005
#   VITE_API_BASE_URL=http://localhost:8005
#   ...but the browser at :8004 will be CORS-blocked unless :8004 is added to the
#   backend DEBUG CORS allowlist (which is hard-coded in code). Prefer proxy mode.
# =============================================================================
