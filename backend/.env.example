# Environment Configuration
ENVIRONMENT=local
DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration
DB_NAME=modernsap
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-business-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-digit-app-password
DEFAULT_FROM_EMAIL=your-business-email@gmail.com

# Alternative Email Services:
# For Brevo (Sendinblue):
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@domain.com
# EMAIL_HOST_PASSWORD=your-smtp-key

# Static Files (Production)
STATIC_ROOT=/var/www/sap-backend/static/
MEDIA_ROOT=/var/www/sap-backend/media/

# Allowed Hosts (Production)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com