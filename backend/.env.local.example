# =============================================================================
# backend/.env.local.example  —  LOCAL DEVELOPMENT environment
# Copy to:  backend/.env     (cp .env.local.example .env)
# All values below are LOCAL DUMMIES / safe defaults. No production secrets.
# Source of truth: backend/sap_backend/settings.py  +  finance/government_api.py
#                  + hr/encryption_utils.py
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — REQUIRED / RECOMMENDED  (app reads these at startup)
# -----------------------------------------------------------------------------

# ENVIRONMENT: 'local' or 'production'. Drives security defaults + enables API docs.
# Default in code: local
ENVIRONMENT=local

# DEBUG: master debug switch (parsed by config_bool; accepts True/1/yes/dev).
# Default in code: False  ->  set True locally so /api/docs, static/media serving work.
DEBUG=True

# SECRET_KEY: Django signing + JWT signing key. Code ships an insecure default and
# REFUSES TO BOOT in production if unchanged. Any non-empty string is fine locally.
# Default in code: django-insecure-...  (dev only)
SECRET_KEY=local-dev-secret-not-for-production

# ALLOWED_HOSTS: comma list. localhost/127.0.0.1 cover local dev (Vite proxy sets
# Host to localhost via changeOrigin).
# Default in code: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL) — REQUIRED  (must match your local Postgres)
# -----------------------------------------------------------------------------
# Defaults in code: modernsap / postgres / mango / localhost / 5432
DB_NAME=modernsap
DB_USER=postgres
DB_PASSWORD=postgres          # <-- set to YOUR local Postgres password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# REDIS — REQUIRED for cache/realtime/Celery  (optional for plain CRUD)
# -----------------------------------------------------------------------------
# Cache uses DB 1; Celery/Channels use DB 0. One local Redis serves all.
# Default in code (cache): redis://localhost:6379/1 ; (channels/celery): .../0
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# CELERY — OPTIONAL (only if running worker/beat for async + scheduled jobs)
# -----------------------------------------------------------------------------
# Defaults in code: redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# CORS / CSRF — DEV NOTE
# -----------------------------------------------------------------------------
# When DEBUG=True, settings.py HARD-CODES the CORS allowlist to ports
# 3000/3001/3002 and IGNORES these env vars. The recommended local setup runs the
# frontend on :8004 and proxies /api + /ws to the backend via Vite, so requests are
# SAME-ORIGIN and CORS never applies. These vars only take effect when DEBUG=False.
# Defaults in code (prod): include sap.athenas.co.in + localhost:3000-3002
CORS_ALLOWED_ORIGINS=http://localhost:8004,http://127.0.0.1:8004,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8004,http://127.0.0.1:8004,http://localhost:3000

# -----------------------------------------------------------------------------
# EMAIL — OPTIONAL locally (use console backend so no real mail is sent)
# -----------------------------------------------------------------------------
# Default backend in code: smtp.EmailBackend (Hostinger). Override to console locally.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=system@example.com
EMAIL_TIMEOUT=30

# -----------------------------------------------------------------------------
# ENCRYPTION KEYS — generate your OWN (do NOT reuse committed defaults)
# -----------------------------------------------------------------------------
# Fernet key used to encrypt per-company SMTP credentials.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Default in code: a committed key (INSECURE — local placeholder below is fine).
EMAIL_ENCRYPTION_KEY=replace_with_generated_fernet_key

# Fernet key used to encrypt HR government-portal credentials (hr/encryption_utils.py).
# OPTIONAL: if unset, a temporary key is auto-generated at runtime (fine for local).
# Generate the same way as above if you want persistence across restarts.
# PORTAL_ENCRYPTION_KEY=replace_with_generated_fernet_key

# -----------------------------------------------------------------------------
# JWT — OPTIONAL (sane defaults in code: 60 min access / 1440 min refresh)
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# -----------------------------------------------------------------------------
# MISC — OPTIONAL
# -----------------------------------------------------------------------------
# FRONTEND_URL: base URL used inside outbound email links. Match your frontend port.
# Default in code: http://localhost:3001
FRONTEND_URL=http://localhost:8004
# BACKUP_DIR: DB backup output dir. Default in code: <backend>/backups
BACKUP_DIR=./backups

# -----------------------------------------------------------------------------
# THIRD-PARTY GOVERNMENT INTEGRATIONS — ALL OPTIONAL locally
# Read lazily (only when those features run); blank/dummy disables them gracefully.
# -----------------------------------------------------------------------------
# GST number verification (finance/government_api.py -> gstincheck.co.in)
GSTINCHECK_API_KEY=dummy

# GST e-filing API (lazy; defaults to public URL + blank creds)
GST_API_BASE_URL=https://api.gst.gov.in
GST_CLIENT_ID=
GST_CLIENT_SECRET=
GST_USERNAME=
GST_PASSWORD=

# TDS / income-tax e-filing API (lazy; blank creds)
TDS_API_BASE_URL=https://incometaxindiaefiling.gov.in
TDS_USERNAME=
TDS_PASSWORD=
COMPANY_PAN=
COMPANY_TAN=

# E-Invoice (IRN) API (lazy; blank creds)
EINVOICE_API_BASE_URL=https://einvoice1.gst.gov.in
EINVOICE_CLIENT_ID=
EINVOICE_CLIENT_SECRET=
COMPANY_GSTIN=

# =============================================================================
# PRODUCTION-ONLY (do NOT set locally; auto-enabled when ENVIRONMENT=production)
#   STATIC_ROOT, MEDIA_ROOT,
#   SECURE_SSL_REDIRECT, SESSION_COOKIE_SECURE, CSRF_COOKIE_SECURE,
#   SECURE_HSTS_SECONDS, SECURE_HSTS_INCLUDE_SUBDOMAINS, SECURE_HSTS_PRELOAD,
#   USE_X_FORWARDED_HOST, USE_X_FORWARDED_PORT
# SCRIPT/TEST-ONLY (not used by the running web app):
#   DJANGO_DEBUG, DJANGO_ENV, TEST_USER_PASSWORD
# =============================================================================
